package rules

import it.tesi.app.model.GameContext;
import it.tesi.app.dto.InventoryItemDto;

rule "Repair axe"
when
    $ctx : GameContext(targetType == "workbench", recipeName == "axe")
    InventoryItemDto(type == "Iron", count >= 3)
    InventoryItemDto(type == "Copper", count >= 3)
    InventoryItemDto(type == "Wood", count >= 4)
then
    $ctx.setAllowed(true);
    $ctx.setAction("repair_tool");
    $ctx.setResultItem("axe");
    $ctx.setResultCount(1);
    $ctx.setMessage("Ascia riparata");
end

rule "Repair pickaxe"
when
    $ctx : GameContext(targetType == "workbench", recipeName == "pickaxe")
    InventoryItemDto(type == "Iron", count >= 2)
    InventoryItemDto(type == "Copper", count >= 3)
    InventoryItemDto(type == "Wood", count >= 4)
then
    $ctx.setAllowed(true);
    $ctx.setAction("repair_tool");
    $ctx.setResultItem("pickaxe");
    $ctx.setResultCount(1);
    $ctx.setMessage("Piccone riparato");
end

rule "Repair sword"
when
