rule "Create wheat fertilizer"
when
    $ctx : GameContext(targetType == "workbench", recipeName == "create", ingredients.size == 1)
    InventoryItemDto(type == "SlimeDrop", count == 4)
then
    $ctx.setAllowed(true);
    $ctx.setAction("craft");
    $ctx.setResultItem("wheatFertilizer");
    $ctx.setResultCount(1);
    $ctx.setMessage("Creato fertilizzante per grano");
end

rule "Create tomato fertilizer"
when
    $ctx : GameContext(targetType == "workbench", recipeName == "create", ingredients.size == 2)
    InventoryItemDto(type == "SlimeDrop", count == 6)
    InventoryItemDto(type == "Apple", count == 2)
then
    $ctx.setAllowed(true);
    $ctx.setAction("craft");
    $ctx.setResultItem("tomatoFertilizer");
    $ctx.setResultCount(1);
    $ctx.setMessage("Creato fertilizzante per pomodoro");
end

